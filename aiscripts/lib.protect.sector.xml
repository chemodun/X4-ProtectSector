<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.protect.sector" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd" version="115">
  <interrupts>
    <library>
      <actions name="ProtectSectorRestoreOrderParamsOnNewCommander">
        <do_if value="@this.$protectSectorParams != null and (player.age - @this.$protectSectorParams.$timeStamp) le 1200s">
          <debug_text
            text="'ProtectSector [%s at %s, %s]: Restoring parameters %s on %s. Version: %s'.
              [
                this.assignedcontrolled.debugname,
                this.assignedcontrolled.sector.knownname,
                this.assignedcontrolled.fleet.name,
                @this.$protectSectorParams,
                @$object.debugname,
                @this.$protectSectorParams.$version
              ]" chance="@this.$protectSectorParams.$debugchance" />
          <set_value name="$orderParams" exact="@this.$protectSectorParams" />
          <do_if value="@$orderParams.$version == 114">
            <create_order object="$object" id="'ProtectSector'" default="true">
              <param name="homeSector" value="$orderParams.$homeSector" />
              <param name="attackStations" value="$orderParams.$attackStations" />
              <param name="attackStationsTactical" value="$orderParams.$attackStationsTactical" />
              <param name="attackStationsInternal" value="$orderParams.$attackStationsInternal" />
              <param name="attackShipsXL" value="$orderParams.$attackShipsXL" />
              <param name="attackShipsL" value="$orderParams.$attackShipsL" />
              <param name="attackShipsM" value="$orderParams.$attackShipsM" />
              <param name="attackShipsS" value="$orderParams.$attackShipsS" />
              <param name="attackShipsOutOfStationsDistance" value="$orderParams.$attackShipsOutOfStationsDistance" />
              <param name="attackVisibleOnly" value="$orderParams.$attackVisibleOnly" />
              <param name="attackHostileOnly" value="$orderParams.$attackHostileOnly" />
              <param name="relationsThreshold" value="$orderParams.$relationsThreshold" />
              <param name="pursueFleeingTarget" value="$orderParams.$pursueFleeingTarget" />
              <param name="protectPlayerShipsInSector" value="$orderParams.$protectPlayerShipsInSector" />
              <param name="protectOnlyNonMilitaryShips" value="$orderParams.$protectOnlyNonMilitaryShips" />
              <param name="shareTargetsBetweenFleets" value="$orderParams.$shareTargetsBetweenFleets" />
              <param name="attackDistanceAsPercentageOfRadarRange" value="$orderParams.$attackDistanceAsPercentageOfRadarRange" />
              <param name="breakOnDestructionPercentage" value="$orderParams.$breakOnDestructionPercentage" />
              <param name="receivedDamageSensitivity" value="2" />
              <param name="parkInSector" value="$orderParams.$parkInCenterOfSector or @$orderParams.$desiredParkingPosition != null" />
              <param name="desiredParkingPosition" value="if @$orderParams.$desiredParkingPosition != null then @$orderParams.$desiredParkingPosition else [$orderParams.$homeSector, $orderParams.$homeSector.coreposition]" />
              <param name="delayBetweenScans" value="$orderParams.$delayBetweenScans" />
              <param name="ignoreHazardThreat" value="$orderParams.$ignoreHazardThreat" />
              <param name="recordActionsToLogBook" value="$orderParams.$recordActionsToLogBook" />
              <param name="isStartedByPlayer" value="false" />
              <param name="debugchance" value="$orderParams.$debugchance" />
            </create_order>
          </do_if>
          <do_if value="@$orderParams.$version ge 115">
            <create_order object="$object" id="'ProtectSector'" default="true">
              <param name="homeSector" value="$orderParams.$homeSector" />
              <param name="attackStations" value="$orderParams.$attackStations" />
              <param name="attackStationsTactical" value="$orderParams.$attackStationsTactical" />
              <param name="attackStationsInternal" value="$orderParams.$attackStationsInternal" />
              <param name="attackShipsXL" value="$orderParams.$attackShipsXL" />
              <param name="attackShipsL" value="$orderParams.$attackShipsL" />
              <param name="attackShipsM" value="$orderParams.$attackShipsM" />
              <param name="attackShipsS" value="$orderParams.$attackShipsS" />
              <param name="attackShipsOutOfStationsDistance" value="$orderParams.$attackShipsOutOfStationsDistance" />
              <param name="attackVisibleOnly" value="$orderParams.$attackVisibleOnly" />
              <param name="attackHostileOnly" value="$orderParams.$attackHostileOnly" />
              <param name="relationsThreshold" value="$orderParams.$relationsThreshold" />
              <param name="pursueFleeingTarget" value="$orderParams.$pursueFleeingTarget" />
              <param name="protectPlayerShipsInSector" value="$orderParams.$protectPlayerShipsInSector" />
              <param name="protectOnlyNonMilitaryShips" value="$orderParams.$protectOnlyNonMilitaryShips" />
              <param name="shareTargetsBetweenFleets" value="$orderParams.$shareTargetsBetweenFleets" />
              <param name="attackDistanceAsPercentageOfRadarRange" value="$orderParams.$attackDistanceAsPercentageOfRadarRange" />
              <param name="breakOnDestructionPercentage" value="$orderParams.$breakOnDestructionPercentage" />
              <param name="receivedDamageSensitivity" value="$orderParams.$receivedDamageSensitivity" />
              <param name="parkInSector" value="$orderParams.$parkInSector" />
              <param name="desiredParkingPosition" value="$orderParams.$desiredParkingPosition" />
              <param name="delayBetweenScans" value="$orderParams.$delayBetweenScans" />
              <param name="ignoreHazardThreat" value="$orderParams.$ignoreHazardThreat" />
              <param name="recordActionsToLogBook" value="$orderParams.$recordActionsToLogBook" />
              <param name="isStartedByPlayer" value="false" />
              <param name="debugchance" value="$orderParams.$debugchance" />
            </create_order>
          </do_if>
        </do_if>
      </actions>
      <actions name="ProtectSectorPrepareOrderParams">
        <set_value name="$protectSectorParams" exact="table[
          $homeSector = $homeSector,
          $attackStations = $attackStations,
          $attackStationsTactical = $attackStationsTactical,
          $attackStationsInternal = $attackStationsInternal,
          $attackShipsXL = $attackShipsXL,
          $attackShipsL = $attackShipsL,
          $attackShipsM = $attackShipsM,
          $attackShipsS = $attackShipsS,
          $attackShipsOutOfStationsDistance = $attackShipsOutOfStationsDistance,
          $attackVisibleOnly = $attackVisibleOnly,
          $attackHostileOnly = $attackHostileOnly,
          $relationsThreshold = $relationsThreshold,
          $pursueFleeingTarget = $pursueFleeingTarget,
          $protectPlayerShipsInSector = $protectPlayerShipsInSector,
          $protectOnlyNonMilitaryShips = $protectOnlyNonMilitaryShips,
          $shareTargetsBetweenFleets = $shareTargetsBetweenFleets,
          $attackDistanceAsPercentageOfRadarRange = $attackDistanceAsPercentageOfRadarRange,
          $breakOnDestructionPercentage = $breakOnDestructionPercentage,
          $receivedDamageSensitivity = $receivedDamageSensitivity,
          $parkInSector = $parkInSector,
          $desiredParkingPosition = $desiredParkingPosition,
          $delayBetweenScans = $delayBetweenScans,
          $ignoreHazardThreat = $ignoreHazardThreat,
          $recordActionsToLogBook = $recordActionsToLogBook,
          $debugchance = $debugchance,
          $timeStamp = player.age,
          $version = @$scriptVersion
          ]" />
        <do_if value="$isAttackingNow? and @$isAttackingNow != true">
          <set_value name="$processed" exact="0" />
          <do_for_each name="$subordinate" in="this.assignedcontrolled.subordinates">
            <do_if value="@$subordinate.pilot != null and @$subordinate.exists and not @$subordinate.iswreck and @$subordinate.isoperational">
              <do_if value="@$subordinate.defaultorder.id == 'Escort' and @$subordinate.defaultorder.$target == this.assignedcontrolled">
                <set_value name="$processed" operation="add" />
                <set_value name="$subordinate.aipilot.$protectSectorParams" exact="$protectSectorParams" />
              </do_if>
            </do_if>
          </do_for_each>
          <debug_text
            text="'ProtectSector [%s at %s, %s]: Prepared order parameters for new commander for subordinates count: %s.'.
              [
                this.assignedcontrolled.debugname,
                this.assignedcontrolled.sector.knownname,
                this.assignedcontrolled.fleet.name,
                @$processed
              ]" chance="$debugchance" />
        </do_if>
      </actions>
      <actions name="ProtectSectorCheckAndSignalForDamage">
        <set_value name="$hullPercentages" exact="if $isAttackingNow then @global.$chemODun.$protectSector.$hullPercentages.$attack else @global.$chemODun.$protectSector.$hullPercentages.$idle" />
        <do_if value="@$hullPercentages != null and typeof $hullPercentages == datatype.table">
          <do_for_each name="$shipClass" in="$hullPercentages.keys.list">
            <do_if value="$shipForDamageCheck.isclass.{class.{$shipClass}}">
              <set_value name="$damageThresholds" exact="$hullPercentages.{$shipClass}" />
              <break />
            </do_if>
          </do_for_each>
          <set_value name="$inAttackModifier" exact="if $isAttackingNow then $isInAttackModifier else 0" />
          <do_if value="$shipForDamageCheck.hullpercentage lt $damageThresholds.{$receivedDamageSensitivity}">
            <debug_text text="'ProtectSector [%s at %s, %s]: Ship %s is damaged, signalling for repair.'
              .[
                this.assignedcontrolled.debugname,
                this.assignedcontrolled.sector.knownname,
                this.assignedcontrolled.fleet.name,
                $shipForDamageCheck.debugname
              ]"
              chance="$debugchance" />
            <set_value name="$shipForDamageCheck.pilot.$playerOwnedWorkaroundForRestock" exact="player.age" />
            <set_value name="$shipIsDamaged" exact="true" />
            <signal_objects object="$shipForDamageCheck" param="'resupply'" param2="[$shipForDamageCheck.hullpercentage lt 100]" param3="$debugchance" delay="100ms" />
          </do_if>
        </do_if>
      </actions>
      <actions name="PlayerShipsRestockWorkaround">
        <do_if value="(@$resupplystations_interrupt.count le 0) and not @$onlyuseresupplierships and this.isplayerowned and (player.age - @this.$playerOwnedWorkaroundForRestock) le 10s">
          <set_value name="$blacklistGroup" exact="blacklistgroup.military" />
          <find_station name="$resupplyStationsByWorkaround" canequipclass="this.assignedcontrolled.class" canbuildclass="$buildclass_interrupt" canbuildships="$buildclass_interrupt != null" canbuildfor="this.owner" hascontrolentity="controlpost.shiptrader" space="player.galaxy" knownto="faction.player" multiple="true" append="true" sortbydistanceto="this.assignedcontrolled" sortdescending="false">
            <match_use_blacklist group="$blacklistGroup" type="blacklisttype.objectactivity" object="this.assignedcontrolled" />
            <match_use_blacklist group="$blacklistGroup" type="blacklisttype.sectoractivity" object="this.assignedcontrolled" />
            <match_use_blacklist group="$blacklistGroup" type="blacklisttype.sectortravel" object="this.assignedcontrolled" />
            <match_relation_to object="this.assignedcontrolled" relation="enemy" comparison="not" />
          </find_station>
          <debug_text text="'PlayerRestockWorkaround[%s]: found %s resupply station(s) in the galaxy.'.[this.ship.debugname, $resupplyStationsByWorkaround.count]" chance="if @global.$chemODun.$protectSector.$debugLog then 100 else 0" />
          <do_all exact="$resupplyStationsByWorkaround.count" counter="$counterOfResupplyStationsByWorkaround" reverse="true">
            <do_if value="this.assignedcontrolled.gatedistance.{$resupplyStationsByWorkaround.{$counterOfResupplyStationsByWorkaround}}.{$blacklistGroup}.{this.assignedcontrolled} lt 0">
              <remove_value name="$resupplyStationsByWorkaround.{$counterOfResupplyStationsByWorkaround}" />
              <debug_text text="'PlayerRestockWorkaround[%s]: removed resupply station %s from the list because of impossible to reach.'.
                  [this.ship.debugname, $resupplyStationsByWorkaround.{$counterOfResupplyStationsByWorkaround}.debugname]" chance="if @global.$chemODun.$protectSector.$debugLog then 100 else 0" />
            </do_if>
          </do_all>
          <do_if value="$resupplyStationsByWorkaround.count gt 0">
            <set_value name="$resupplystations_interrupt" exact="$resupplyStationsByWorkaround" />
            <debug_text text="'PlayerRestockWorkaround[%s]: found %s resupply station(s) to the interrupt variable.'.
              [this.ship.debugname, $resupplystations_interrupt.count]" chance="if @global.$chemODun.$protectSector.$debugLog then 100 else 0" />
          </do_if>
          <remove_value name="$resupplyStationsByWorkaround" />
          <remove_value name="$blacklistGroup" />
        </do_if>
      </actions>
    </library>
  </interrupts>
</aiscript>