<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.protect.sector" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">
  <interrupts>
    <library>
      <actions name="ProtectSectorRestoreOrderParamsOnNewCommander">
        <do_if value="@this.$protectSectorParams != null and (player.age - @this.$protectSectorParams.$timeStamp) le 1200s">
          <debug_text
            text="'ProtectSector [%s at %s, %s]: Restoring parameters %s on %s. Version: %s'.
              [
                this.assignedcontrolled.debugname,
                this.assignedcontrolled.sector.knownname,
                this.assignedcontrolled.fleet.name,
                @this.$protectSectorParams,
                @$object.debugname,
                @this.$protectSectorParams.$version
              ]" chance="@this.$protectSectorParams.$debugchance" />
          <set_value name="$orderParams" exact="@this.$protectSectorParams" />
          <do_if value="@$orderParams.$version ge 114">
            <create_order object="$object" id="'ProtectSector'" default="true">
              <param name="homeSector" value="$orderParams.$homeSector" />
              <param name="attackStations" value="$orderParams.$attackStations" />
              <param name="attackStationsTactical" value="$orderParams.$attackStationsTactical" />
              <param name="attackStationsInternal" value="$orderParams.$attackStationsInternal" />
              <param name="attackShipsXL" value="$orderParams.$attackShipsXL" />
              <param name="attackShipsL" value="$orderParams.$attackShipsL" />
              <param name="attackShipsM" value="$orderParams.$attackShipsM" />
              <param name="attackShipsS" value="$orderParams.$attackShipsS" />
              <param name="attackShipsOutOfStationsDistance" value="$orderParams.$attackShipsOutOfStationsDistance" />
              <param name="attackVisibleOnly" value="$orderParams.$attackVisibleOnly" />
              <param name="attackHostileOnly" value="$orderParams.$attackHostileOnly" />
              <param name="relationsThreshold" value="$orderParams.$relationsThreshold" />
              <param name="pursueFleeingTarget" value="$orderParams.$pursueFleeingTarget" />
              <param name="protectPlayerShipsInSector" value="$orderParams.$protectPlayerShipsInSector" />
              <param name="protectOnlyNonMilitaryShips" value="$orderParams.$protectOnlyNonMilitaryShips" />
              <param name="shareTargetsBetweenFleets" value="$orderParams.$shareTargetsBetweenFleets" />
              <param name="attackDistanceAsPercentageOfRadarRange" value="$orderParams.$attackDistanceAsPercentageOfRadarRange" />
              <param name="breakOnDestructionPercentage" value="$orderParams.$breakOnDestructionPercentage" />
              <param name="parkInCenterOfSector" value="$orderParams.$parkInCenterOfSector" />
              <param name="desiredParkingPosition" value="$orderParams.$desiredParkingPosition" />
              <param name="delayBetweenScans" value="$orderParams.$delayBetweenScans" />
              <param name="ignoreHazardThreat" value="$orderParams.$ignoreHazardThreat" />
              <param name="recordActionsToLogBook" value="$orderParams.$recordActionsToLogBook" />
              <param name="isStartedByPlayer" value="false" />
              <param name="debugchance" value="$orderParams.$debugchance" />
            </create_order>
          </do_if>
        </do_if>
      </actions>
      <actions name="ProtectSectorPrepareOrderParams">
        <set_value name="$protectSectorParams" exact="table[
          $homeSector = $homeSector,
          $attackStations = $attackStations,
          $attackStationsTactical = $attackStationsTactical,
          $attackStationsInternal = $attackStationsInternal,
          $attackShipsXL = $attackShipsXL,
          $attackShipsL = $attackShipsL,
          $attackShipsM = $attackShipsM,
          $attackShipsS = $attackShipsS,
          $attackShipsOutOfStationsDistance = $attackShipsOutOfStationsDistance,
          $attackVisibleOnly = $attackVisibleOnly,
          $attackHostileOnly = $attackHostileOnly,
          $relationsThreshold = $relationsThreshold,
          $pursueFleeingTarget = $pursueFleeingTarget,
          $protectPlayerShipsInSector = $protectPlayerShipsInSector,
          $protectOnlyNonMilitaryShips = $protectOnlyNonMilitaryShips,
          $shareTargetsBetweenFleets = $shareTargetsBetweenFleets,
          $attackDistanceAsPercentageOfRadarRange = $attackDistanceAsPercentageOfRadarRange,
          $breakOnDestructionPercentage = $breakOnDestructionPercentage,
          $parkInCenterOfSector = $parkInCenterOfSector,
          $desiredParkingPosition = $desiredParkingPosition,
          $delayBetweenScans = $delayBetweenScans,
          $ignoreHazardThreat = $ignoreHazardThreat,
          $recordActionsToLogBook = $recordActionsToLogBook,
          $debugchance = $debugchance,
          $timeStamp = player.age,
          $version = @$scriptVersion
          ]" />
        <do_if value="$isAttackingNow? and @$isAttackingNow != true">
          <set_value name="$processed" exact="0" />
          <do_for_each name="$subordinate" in="this.assignedcontrolled.subordinates">
            <do_if value="@$subordinate.pilot != null and @$subordinate.exists and not @$subordinate.iswreck and @$subordinate.isoperational">
              <do_if value="@$subordinate.defaultorder.id == 'Escort' and @$subordinate.defaultorder.$target == this.assignedcontrolled">
                <set_value name="$processed" operation="add" />
                <set_value name="$subordinate.aipilot.$protectSectorParams" exact="$protectSectorParams" />
              </do_if>
            </do_if>
          </do_for_each>
          <debug_text
            text="'ProtectSector [%s at %s, %s]: Prepared order parameters for new commander for subordinates count: %s.'.
              [
                this.assignedcontrolled.debugname,
                this.assignedcontrolled.sector.knownname,
                this.assignedcontrolled.fleet.name,
                @$processed
              ]" chance="$debugchance" />
        </do_if>
      </actions>
    </library>
  </interrupts>
</aiscript>