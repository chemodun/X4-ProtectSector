<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Protect_Sector_Options_Menu" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <cues>
    <cue name="Init" instantiate="false" version="2">
      <actions>
        <set_value name="$sensitivityLevels" exact="[{1001, 7736}, {1001, 7737}, {1001, 7738}]" />
        <set_value name="$shipClasses" exact="['ship_s', 'ship_m', 'ship_l', 'ship_xl']" />
        <set_value name="$shipClassNames" exact="[{1001, 51}, {1001, 50}, {1001, 49}, {1001, 48}]" />
        <set_value name="$states" exact="['idle', 'attack']" />
        <set_value name="$stateColors" exact="['Color.text_positive', 'Color.text_negative']" />
        <set_value name="$stateNames" exact="[{1972092401, 90005}, {1972092401, 90006}]" />
        <set_value name="$debugChance" exact="0" />
      </actions>
      <patch sinceversion="2">
        <set_value name="$shipClasses" exact="['ship_s', 'ship_m', 'ship_l', 'ship_xl']" />
        <set_value name="$states" exact="['idle', 'attack']" />
        <set_value name="$stateColors" exact="['Color.text_positive', 'Color.text_negative']" />
        <set_value name="$debugChance" exact="0" />
      </patch>
      <cues>
        <library name="Ensure_Variables" purpose="include_actions" version="2">
          <actions>
            <do_if value="@global.$chemODun == null">
              <set_value name="global.$chemODun" exact="table[]" />
            </do_if>
            <do_if value="@global.$chemODun.$protectSector == null">
              <set_value name="global.$chemODun.$protectSector" exact="table[]" />
            </do_if>
            <do_if value="@global.$chemODun.$protectSector.$debugLog == null">
              <set_value name="global.$chemODun.$protectSector.$debugLog" exact="false" />
            </do_if>
            <do_if value="@global.$chemODun.$protectSector.$hullPercentages == null">
              <set_value name="global.$chemODun.$protectSector.$hullPercentages" exact="table[
                $ship_s = table[
                  $attack = [70, 80, 90],
                  $idle = [80, 90, 100],
                ],
                $ship_m = table[
                  $attack = [55, 70, 85],
                  $idle = [60, 75, 90],
                ],
                $ship_l = table[
                  $attack = [40, 60, 80],
                  $idle = [50, 70, 90],
                ],
                $ship_xl = table[
                  $attack = [30, 50, 70],
                  $idle = [40, 60, 80],
                ],
              ]" />
            </do_if>
            <debug_text
              text="'ProtectSector Options: Ensured variables are initialized: Debug Log: %s, Hull Percentages: %s. All data: %s' .
              [@global.$chemODun.$protectSector.$debugLog, @global.$chemODun.$protectSector.$hullPercentages, @global.$chemODun.$protectSector]"
              filter="scripts" />
            <set_value name="$debugChance" exact="if global.$chemODun.$protectSector.$debugLog then 100 else 0" />
          </actions>
        </library>

        <cue name="Register_Menu" instantiate="true" version="2">
          <conditions>
            <event_cue_signalled cue="md.Simple_Menu_API.Reloaded" />
          </conditions>
          <actions>
            <include_actions ref="Ensure_Variables" />
            <debug_text text="'ProtectSector Options: Registering Options Menus'" filter="scripts" chance="$debugChance" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
              param="table[
                $id      = 'protect_sector_options_menu',
                $columns = 12,
                $title   = {1972092401, 1},
                $onOpen  = Protect_Sector_Options_Menu,
              ]" />
            <set_value name="$sensitivityLevels" exact="[{1001, 7736}, {1001, 7737}, {1001, 7738}]" />
            <set_value name="$shipClassNames" exact="[{1001, 51}, {1001, 50}, {1001, 49}, {1001, 48}]" />
            <set_value name="$stateNames" exact="[{1972092401, 90005}, {1972092401, 90006}]" />
          </actions>
        </cue>

        <cue name="Protect_Sector_Options_Menu" instantiate="true" version="2">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <debug_text text="'ProtectSector Options: Opening ProtectSector Options Menu'" filter="scripts" />
            <include_actions ref="Ensure_Variables" />
            <debug_text text="'ProtectSector Options: Ship classes: %s, states: %s, sensitivity levels: %s.' .
              [@$shipClasses, @$states, @$sensitivityLevels]" chance="$debugChance" filter="scripts" />
            <include_actions ref="Menu_Section_Damage_Sensitivity" />
            <include_actions ref="Menu_Section_Other" />
          </actions>
        </cue>

        <library name="Menu_Section_Damage_Sensitivity" purpose="include_actions">
          <actions>
            <run_actions ref="Add_Title_Row">
              <param name="title" value="{1972092401, 90000}" />
            </run_actions>
            <run_actions ref="Add_SubTitle_Row">
              <param name="text" value="{1972092401, 90001}" />
              <param name="col" value="1" />
              <param name="colSpan" value="1" />
            </run_actions>
            <run_actions ref="Add_SubTitle_Row">
              <param name="text" value="{1972092401, 90002}" />
              <param name="col" value="2" />
              <param name="colSpan" value="1" />
            </run_actions>
            <run_actions ref="Add_SubTitle_Row">
              <param name="text" value="{1972092401, 90003}" />
              <param name="col" value="3" />
              <param name="colSpan" value="2" />
            </run_actions>
            <run_actions ref="Add_SubTitle_Row">
              <param name="text" value="{1972092401, 90004}" />
              <param name="col" value="5" />
              <param name="colSpan" value="8" />
            </run_actions>
            <include_actions ref="Add_Empty_Row" />
            <set_value name="$hullPercentages" exact="@global.$chemODun.$protectSector.$hullPercentages" />
            <do_for_each name="$class" in="@$shipClasses" counter="$i">
              <set_value name="$classId" exact="'$%s' .[@$class]" />
              <set_value name="$className" exact="@$shipClassNames.{$i}" />
              <set_value name="$classValues" exact="@$hullPercentages.{$classId}" />
              <include_actions ref="Ship_Class_And_Level_Controls" />
              <remove_value name="$classId" />
              <remove_value name="$className" />
              <remove_value name="$classValues" />
            </do_for_each>
            <remove_value name="$hullPercentages" />
          </actions>
        </library>

        <library name="Menu_Section_Other" purpose="include_actions" version="1">
          <actions>
            <include_actions ref="Add_Empty_Row" />
            <run_actions ref="Add_Title_Row">
              <param name="title" value="{1972092401, 99000}" />
            </run_actions>
            <run_actions ref="Add_CheckBox">
              <param name="id" value="'protect_sector_debug_log'" />
              <param name="checked" value="@global.$chemODun.$protectSector.$debugLog" />
              <param name="col" value="1" />
              <param name="textColSpan" value="11" />
              <param name="text" value="{1972092401, 99010}" />
            </run_actions>
          </actions>
        </library>

        <library name="Add_Title_Row" purpose="run_actions">
          <params>
            <param name="title" />
          </params>
          <actions>
            <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col = 1,
                $colSpan = 12,
                $fontsize = 'Helper.titleFontSize',
                $titleColor = 'Color.text_normal',
                $halign = 'center',
                $text = $title,
              ]" />
            <include_actions ref="Add_Empty_Row" />
          </actions>
        </library>

        <library name="Add_SubTitle_Row" purpose="run_actions">
          <params>
            <param name="text" />
            <param name="col" default="1" />
            <param name="colSpan" default="12" />
            <param name="halign" default="'center'" />
          </params>
          <actions>
            <do_if value="@$col == 1">
              <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            </do_if>
            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col = @$col,
                $colSpan = @$colSpan,
                $fontsize = 'Helper.headerRow1FontSize',
                $titleColor = 'Color.text_normal',
                $halign = @$halign,
                $text = @$text,
              ]" />
            <do_if value="(@$col + @$colSpan) == 12">
              <include_actions ref="Add_Empty_Row" />
            </do_if>
          </actions>
        </library>

        <library name="Add_Empty_Row" purpose="include_actions">
          <actions>
            <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            <signal_cue_instantly
              cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col = 1,
                $colSpan = 12,
                $height = 'Helper.borderSize',
                $fontsize = 'Helper.borderSize',
                ]" />
          </actions>
        </library>

        <library name="Ship_Class_And_Level_Controls" purpose="include_actions">
          <actions>
            <debug_text text="'ProtectSector Options: Adding controls for class %s with values: %s.' .[@$class, @$classValues]" chance="@$debugChance" filter="scripts" />
            <do_for_each name="$state" in="@$states" counter="$j">
              <set_value name="$stateId" exact="'$%s' .[@$state]" />
              <set_value name="$stateValues" exact="@$classValues.{$stateId}" />
              <debug_text text="'ProtectSector Options: Adding controls for state %s with values %s.' .[@$state, @$stateValues]" chance="@$debugChance" filter="scripts" />
              <do_for_each name="$sensitivityLevel" in="@$sensitivityLevels" counter="$k">
                <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
                <do_if value="$k == 1">
                  <do_if value="$j == 1">
                    <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                      param="table[
                        $col = 1,
                        $colSpan = 1,
                        $halign = 'center',
                        $font = 'Helper.standardFontBold',
                        $fontsize = 'Helper.titleFontSize',
                        $text = @$className,
                      ]" />
                  </do_if>
                  <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                    param="table[
                      $col = 2,
                      $colSpan = 1,
                      $halign = 'center',
                      $text = $stateNames.{$j},
                      $color = @$stateColors.{$j},
                    ]" />
                </do_if>
                <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                  param="table[
                    $col = 3,
                    $colSpan = 2,
                    $halign = 'center',
                    $text = $sensitivityLevels.{$k},
                  ]" />
                <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider"
                  param="table[
                    $id = 'sensitivity_%s_%s_%s' .[@$class, @$state, $k],
                    $col = 5,
                    $colSpan = 8,
                    $min = 10,
                    $max = 100,
                    $step = 5,
                    $start = @$stateValues.{$k},
                    $onSliderCellConfirm = Handle_Slider_Changed,
                    $echo = table [
                      $class = '$%s'.[@$class],
                      $state = @$stateId,
                      $level = $k,
                    ],
                  ]" />
              </do_for_each>
              <remove_value name="$stateId" />
              <remove_value name="$stateValues" />
              <include_actions ref="Add_Empty_Row" />
            </do_for_each>
            <include_actions ref="Add_Empty_Row" />
          </actions>
        </library>


        <library name="Add_CheckBox" purpose="run_actions">
          <params>
            <param name="id" />
            <param name="checked" default="false" />
            <param name="col" default="1" />
            <param name="textColSpan" default="1" />
            <param name="text" default="''" />
          </params>
          <actions>
            <do_if value="@$id != null and $checked? and $col? and $textColSpan? and @$text != null">
              <do_if value="@$col == 1">
                <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
              </do_if>
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox"
                param="table[
                $id = @$id,
                $checked = @$checked,
                $col = @$col,
                $colSpan = 1,
                $x = 20,
                $width = 'Helper.standardButtonHeight',
                $height = 'Helper.standardButtonHeight',
                $onClick = Handle_Checkbox_Changed
              ]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                param="table[
                $col = @$col + 1,
                $colSpan = @$textColSpan,
                $halign = 'left',
                $text = @$text,
              ]" />
            </do_if>
          </actions>
        </library>

        <cue name="Handle_Checkbox_Changed" instantiate="true" version="1">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <include_actions ref="Ensure_Variables" />
            <debug_text text="'ProtectSector Options: Checkbox %s changed to %s.' .[event.param.$id, event.param.$checked]" chance="@$debugChance" filter="scripts" />
            <set_value name="$id" exact="event.param.$id" />
            <do_if value="event.param.$id == 'protect_sector_debug_log'">
              <set_value name="global.$chemODun.$protectSector.$debugLog" exact="if event.param.$checked then true else false" />
            </do_if>
            <remove_value name="$id" />
          </actions>
        </cue>

        <cue name="Handle_Slider_Changed" instantiate="true" version="1">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <include_actions ref="Ensure_Variables" />
            <set_value name="$hullPercentages" exact="@global.$chemODun.$protectSector.$hullPercentages" />
            <debug_text text="'ProtectSector Options: Slider %s changed to %s. Echo: %s' .[event.param.$id, event.param.$value, event.param.$echo]" chance="@$debugChance" filter="scripts" />
            <set_value name="$id" exact="event.param.$id" />
            <set_value name="$value" exact="event.param.$value" />
            <set_value name="$class" exact="event.param.$echo.$class" />
            <set_value name="$state" exact="event.param.$echo.$state" />
            <set_value name="$level" exact="event.param.$echo.$level" />
            <debug_text text="'ProtectSector Options: Handling slider change for class %s and state %s with new value %s. Old value: %s' .
              [@$class, @$state, @$value, @$hullPercentages.{@$class}.{@$state}.{@$level}]" chance="@$debugChance" filter="scripts" />
            <set_value name="$hullPercentages.{$class}.{$state}.{$level}" exact="$value" />
            <remove_value name="$id" />
            <remove_value name="$value" />
            <remove_value name="$class" />
            <remove_value name="$state" />
            <remove_value name="$level" />
            <remove_value name="$hullPercentages" />
          </actions>
        </cue>

      </cues>
    </cue>


  </cues>
</mdscript>